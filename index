    setShowAddSection(false);
  };

  const updateDayTitle = (dayId,val)=>setDays(p=>p.map(d=>d.id!==dayId?d:{...d,title:val}));

  // Chat
  const sendChat = async()=>{
    if(!chatIn.trim()||chatLoading) return;
    const msg=chatIn; setChatIn(""); setChatLoading(true);
    setMsgs(p=>[...p,{role:"user",content:msg}]);
    const history=[...msgs,{role:"user",content:msg}].map(m=>({role:m.role,content:m.content}));
    const reply = await aiChat(msg,days,history.slice(0,-1));
    setMsgs(p=>[...p,{role:"assistant",content:reply}]);
    setChatLoading(false);
  };

  // Photos
  const processFile = useCallback(async(file)=>{
    if(!file.type.startsWith("image/")) return;
    const url=URL.createObjectURL(file);
    const id=Date.now()+Math.random();
    setPhotos(p=>[...p,{id,url,loading:true}]);
    const b64=await new Promise(res=>{const r=new FileReader();r.onload=()=>res(r.result.split(",")[1]);r.readAsDataURL(file);});
    try{
      const info=await aiPhoto(b64,file.type,days);
      setPhotos(p=>p.map(ph=>ph.id!==id?ph:{...ph,loading:false,...info}));
    }catch{
      setPhotos(p=>p.map(ph=>ph.id!==id?ph:{...ph,loading:false,location:"Portugal",caption:"A beautiful moment.",mood:"golden"}));
    }
  },[days]);

  const onDrop=useCallback(async e=>{
    e.preventDefault();setDragging(false);
    for(const f of Array.from(e.dataTransfer.files).filter(f=>f.type.startsWith("image/"))) await processFile(f);
  },[processFile]);

  const filteredPhotos = filterDay?photos.filter(p=>p.dayId===filterDay):photos;
  const TABS=[["itinerary","🗺 Itinerary"],["bookings",`📋 Bookings`],["photos",`📸 Photos${photos.length?` (${photos.length})`:""}`],["upload","＋ Add Photos"]];

  return (
    <div style={{fontFamily:"'EB Garamond',Georgia,serif",background:"#080808",minHeight:"100vh",color:"#E8DDD0"}}>

      {/* HEADER */}
      <div style={{background:"#080808",borderBottom:"1px solid #151515",padding:"16px 20px 0",position:"sticky",top:0,zIndex:50,backdropFilter:"blur(8px)"}}>
        <div style={{maxWidth:980,margin:"0 auto"}}>
          <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:10,marginBottom:6}}>
            <div>
              <div style={{fontSize:10,letterSpacing:4,color:"#C4974A",textTransform:"uppercase",marginBottom:2}}>July 3–12, 2026 · Algarve + Lisbon</div>
              <h1 style={{fontSize:"clamp(16px,2.5vw,26px)",fontWeight:400,color:"#F5ECD8",letterSpacing:-.5}}>🇵🇹 Portugal <span style={{color:"#C4974A",fontStyle:"italic"}}>Complete Trip Guide</span></h1>
            </div>
            <div style={{display:"flex",gap:8,alignItems:"center"}}>
              <span style={{fontSize:11,color:saved?"#2D9E6B":"#555"}}>{saved?"✓ Saved":"Saving…"}</span>
              <button onClick={()=>{ if(confirm("Reset all edits to original itinerary?")){ localStorage.removeItem(LS_KEY); setDays(INITIAL_DAYS); setBookings(INITIAL_BOOKINGS); }}} style={{background:"none",border:"1px solid #1a1a1a",borderRadius:6,padding:"5px 10px",cursor:"pointer",fontSize:11,color:"#333"}}>Reset</button>
              <button onClick={()=>setChatOpen(o=>!o)} style={{background:chatOpen?"#C4974A":"#12100a",border:`1px solid ${chatOpen?"#C4974A":"#2a2010"}`,borderRadius:18,padding:"6px 16px",cursor:"pointer",color:chatOpen?"#000":"#C4974A",fontSize:12,transition:"all .2s"}}>✦ AI {chatOpen?"▲":"▼"}</button>
            </div>
          </div>
          <div style={{display:"flex",gap:0,overflowX:"auto",scrollbarWidth:"none"}}>
            {TABS.map(([id,label])=>(
              <button key={id} onClick={()=>setTab(id)} style={{flexShrink:0,background:"none",border:"none",color:tab===id?"#C4974A":"#444",cursor:"pointer",padding:"8px 14px",fontSize:13,borderBottom:tab===id?"2px solid #C4974A":"2px solid transparent",whiteSpace:"nowrap"}}>{label}</button>
            ))}
          </div>
        </div>
      </div>

      {/* AI CHAT */}
      {chatOpen&&(
        <div style={{background:"#060604",borderBottom:"1px solid #181410",padding:"0 20px"}}>
          <div style={{maxWidth:980,margin:"0 auto",padding:"12px 0"}}>
            <div style={{background:"#0a0906",border:"1px solid #201810",borderRadius:12,overflow:"hidden"}}>
              <div style={{padding:"12px 16px",maxHeight:200,overflowY:"auto"}}>
                {msgs.map((m,i)=>(
                  <div key={i} style={{display:"flex",gap:8,marginBottom:8,justifyContent:m.role==="user"?"flex-end":"flex-start"}}>
                    {m.role==="assistant"&&<div style={{color:"#C4974A",fontSize:14,flexShrink:0,marginTop:2}}>✦</div>}
                    <div style={{maxWidth:"80%",background:m.role==="user"?"#1a1208":"#111",border:`1px solid ${m.role==="user"?"#C4974A22":"#1a1a1a"}`,borderRadius:10,padding:"8px 12px",fontSize:13,color:"#C8C0B8",lineHeight:1.65,whiteSpace:"pre-wrap"}}>{m.content}</div>
                  </div>
                ))}
                {chatLoading&&<div style={{display:"flex",gap:8}}><div style={{color:"#C4974A"}}>✦</div><div style={{background:"#111",border:"1px solid #1a1a1a",borderRadius:10,padding:"8px 12px",fontSize:13,color:"#555"}}>Thinking…</div></div>}
                <div ref={chatEnd}/>
              </div>
              <div style={{borderTop:"1px solid #141414",padding:"8px 12px",display:"flex",gap:8}}>
                <input value={chatIn} onChange={e=>setChatIn(e.target.value)} onKeyDown={e=>e.key==="Enter"&&sendChat()} placeholder="Ask anything — alternatives, tips, restaurant swaps…" style={{flex:1,background:"#0D0D0D",border:"1px solid #1e1e1e",borderRadius:7,padding:"7px 11px",color:"#E8DDD0",fontSize:13,fontFamily:"'EB Garamond',Georgia,serif",outline:"none"}}/>
                <button onClick={sendChat} disabled={chatLoading||!chatIn.trim()} style={{background:chatLoading?"#222":"#C4974A",border:"none",borderRadius:7,padding:"7px 16px",cursor:"pointer",color:"#000",fontSize:13}}>Send</button>
              </div>
            </div>
          </div>
        </div>
      )}

      <div style={{maxWidth:980,margin:"0 auto",padding:"22px 20px"}}>

        {/* ── ITINERARY ── */}
        {tab==="itinerary"&&(
          <div>
            {/* Day selector */}
            <div style={{display:"flex",gap:5,overflowX:"auto",paddingBottom:14,marginBottom:18,scrollbarWidth:"none"}}>
              {days.map((d,i)=>(
                <button key={d.id} onClick={()=>setDayIdx(i)} style={{flexShrink:0,background:dayIdx===i?d.theme:"#0f0f0f",border:`1px solid ${dayIdx===i?d.theme:"#1c1c1c"}`,borderRadius:8,padding:"9px 11px",cursor:"pointer",textAlign:"center",minWidth:62,transition:"all .2s"}}>
                  <div style={{fontSize:17,marginBottom:2}}>{d.emoji}</div>
                  <div style={{fontSize:10,color:dayIdx===i?"#fff":"#666",letterSpacing:.8,textTransform:"uppercase"}}>{d.date.split(" ")[1]}</div>
                  <div style={{fontSize:8,color:dayIdx===i?"rgba(255,255,255,.65)":"#333",textTransform:"uppercase",marginTop:1}}>{d.label}</div>
                </button>
              ))}
            </div>

            {/* Day header */}
            <div style={{background:`linear-gradient(135deg,${cur.theme}1a,${cur.theme}06)`,border:`1px solid ${cur.theme}33`,borderRadius:12,padding:"16px 20px",marginBottom:18}} className="fade">
              <div style={{fontSize:10,letterSpacing:4,color:cur.theme,textTransform:"uppercase",marginBottom:4}}>{cur.date} · {cur.day}</div>
              <h2 style={{margin:0,fontSize:"clamp(14px,2.2vw,20px)",fontWeight:400,color:"#F0E8DC"}}>
                <Editable value={cur.title} onChange={v=>updateDayTitle(cur.id,v)} style={{fontSize:"clamp(14px,2.2vw,20px)",color:"#F0E8DC"}}/>
              </h2>
            </div>

            {/* Sections */}
            {cur.sections.map(sec=>(
              <div key={sec.id} className="fade" style={{marginBottom:18}}>
                {sec.type==="logistics"
                  ? <LogisticsSection section={sec} theme={cur.theme} dayId={cur.id}
                      onUpdateSection={val=>updateSection(cur.id,sec.id,val)}
                      onDeleteSection={()=>deleteSection(cur.id,sec.id)}/>
                  : <ActivitySection section={sec} theme={cur.theme} dayCtx={`${cur.date} ${cur.day} — ${cur.title}`}
                      onUpdateSection={val=>updateSection(cur.id,sec.id,val)}
                      onDeleteSection={()=>deleteSection(cur.id,sec.id)}/>
                }
              </div>
            ))}

            {/* Add Section */}
            <div style={{marginTop:8}}>
              {!showAddSection
                ? <button onClick={()=>setShowAddSection(true)} style={{width:"100%",background:"none",border:"1px dashed #1e1e1e",borderRadius:10,padding:"12px",cursor:"pointer",fontSize:12,color:"#333",textAlign:"center"}}>+ Add Section to {cur.date}</button>
                : <div style={{background:"#0a0a0a",border:"1px solid #222",borderRadius:10,padding:"14px"}} className="fade">
                    <div style={{fontSize:10,color:"#555",letterSpacing:2,textTransform:"uppercase",marginBottom:10}}>New Section</div>
                    <div style={{display:"grid",gridTemplateColumns:"auto 1fr auto",gap:8,marginBottom:10,alignItems:"center"}}>
                      <input value={newSection.icon} onChange={e=>setNewSection(p=>({...p,icon:e.target.value}))} style={{width:44,background:"#111",border:"1px solid #1e1e1e",borderRadius:5,padding:"6px 8px",color:"#D4C8B8",fontSize:16,textAlign:"center",fontFamily:"'EB Garamond',Georgia,serif",outline:"none"}}/>
                      <input value={newSection.title} onChange={e=>setNewSection(p=>({...p,title:e.target.value}))} placeholder="Section title (e.g. Afternoon, Morning Hike)" style={{background:"#111",border:"1px solid #1e1e1e",borderRadius:5,padding:"6px 10px",color:"#D4C8B8",fontSize:13,fontFamily:"'EB Garamond',Georgia,serif",outline:"none"}}/>
                      <select value={newSection.type} onChange={e=>setNewSection(p=>({...p,type:e.target.value}))} style={{background:"#111",border:"1px solid #1e1e1e",borderRadius:5,padding:"6px 8px",color:"#888",fontSize:12,outline:"none"}}>
                        <option value="activity">Activity</option>
                        <option value="dinner">Dinner</option>
                        <option value="logistics">Logistics</option>
                      </select>
                    </div>
                    <div style={{display:"flex",gap:8}}>
                      <button onClick={()=>addSection(cur.id)} disabled={!newSection.title.trim()} style={{background:newSection.title.trim()?"#C4974A":"#222",border:"none",borderRadius:6,padding:"7px 18px",cursor:newSection.title.trim()?"pointer":"not-allowed",color:newSection.title.trim()?"#000":"#555",fontSize:13}}>Add Section</button>
                      <button onClick={()=>setShowAddSection(false)} style={{background:"none",border:"1px solid #222",borderRadius:6,padding:"7px 14px",cursor:"pointer",color:"#555",fontSize:13}}>Cancel</button>
                    </div>
                  </div>
              }
            </div>
          </div>
        )}

        {/* ── BOOKINGS ── */}
        {tab==="bookings"&&(
          <div>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
              <h2 style={{color:"#C4974A",fontSize:20,fontWeight:400}}>Booking Checklist</h2>
              <button onClick={()=>setBookings(p=>[...p,{id:uid(),priority:"medium",when:"",night:"",name:"New booking",action:"",link:"",done:false}])} style={{background:"none",border:"1px solid #C4974A33",borderRadius:6,padding:"5px 14px",cursor:"pointer",fontSize:12,color:"#C4974A88"}}>+ Add</button>
            </div>
            <p style={{color:"#555",fontSize:13,marginBottom:24}}>Ocean Restaurant books 3 months out in summer — book today if you haven't.</p>
            {["critical","high","medium"].map(p=>(
              <div key={p} style={{marginBottom:26}}>
                <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:10}}>
                  <div style={{width:7,height:7,borderRadius:"50%",background:PC[p]}}/>
                  <div style={{fontSize:10,letterSpacing:3,color:PC[p],textTransform:"uppercase"}}>{PL[p]}</div>
                </div>
                {bookings.filter(b=>b.priority===p).map(item=>(
                  <div key={item.id} style={{background:item.done?"#0a0a0a":"#0f0f0f",border:`1px solid ${item.done?"#111":"#1c1c1c"}`,borderLeft:`3px solid ${item.done?"#333":PC[p]}`,borderRadius:8,padding:"11px 14px",marginBottom:7,opacity:item.done?.6:1}}>
                    <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",flexWrap:"wrap",gap:8}}>
                      <div style={{flex:1}}>
                        <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:3}}>
                          <input type="checkbox" checked={item.done} onChange={e=>setBookings(p=>p.map(b=>b.id!==item.id?b:{...b,done:e.target.checked}))} style={{accentColor:PC[item.priority],width:14,height:14,cursor:"pointer",flexShrink:0}}/>
                          <div style={{fontSize:14,color:item.done?"#444":"#E0D8D0",textDecoration:item.done?"line-through":"none"}}>
                            <Editable value={item.name} onChange={v=>setBookings(p=>p.map(b=>b.id!==item.id?b:{...b,name:v}))} style={{fontSize:14,color:item.done?"#444":"#E0D8D0"}}/>
                          </div>
                        </div>
                        <div style={{fontSize:12,color:"#555",paddingLeft:22}}>
                          📅 <Editable value={item.night} onChange={v=>setBookings(p=>p.map(b=>b.id!==item.id?b:{...b,night:v}))} style={{fontSize:12,color:"#555"}} placeholder="date"/>
                          {" — "}
                          <Editable value={item.action} onChange={v=>setBookings(p=>p.map(b=>b.id!==item.id?b:{...b,action:v}))} style={{fontSize:12,color:"#555"}} placeholder="action"/>
                        </div>
                      </div>
                      <div style={{display:"flex",gap:6,alignItems:"center",flexShrink:0}}>
                        <select value={item.priority} onChange={e=>setBookings(p=>p.map(b=>b.id!==item.id?b:{...b,priority:e.target.value}))} style={{background:"#111",border:`1px solid ${PC[item.priority]}33`,borderRadius:5,padding:"3px 6px",color:PC[item.priority],fontSize:10,outline:"none",cursor:"pointer"}}>
                          <option value="critical">BOOK NOW</option>
                          <option value="high">BOOK SOON</option>
                          <option value="medium">PLAN AHEAD</option>
                        </select>
                        {item.link&&<a href={item.link} target="_blank" rel="noreferrer" style={{fontSize:12,color:"#C4974A",background:"#1a1208",border:"1px solid #C4974A22",padding:"3px 9px",borderRadius:4}}>Book →</a>}
                        <button onClick={()=>setBookings(p=>p.filter(b=>b.id!==item.id))} style={{background:"none",border:"none",cursor:"pointer",fontSize:13,color:"#222",padding:"2px 4px"}}>×</button>
                      </div>
                    </div>
                  </div>
                ))}
                {bookings.filter(b=>b.priority===p).length===0&&<div style={{fontSize:12,color:"#2a2a2a",fontStyle:"italic",padding:"6px 0"}}>None</div>}
              </div>
            ))}
          </div>
        )}

        {/* ── PHOTOS ── */}
        {tab==="photos"&&(
          <div>
            {photos.length>0&&(
              <div style={{display:"flex",gap:5,overflowX:"auto",paddingBottom:12,marginBottom:18,scrollbarWidth:"none"}}>
                <button onClick={()=>setFilterDay(null)} style={{flexShrink:0,background:!filterDay?"#C4974A":"#111",border:`1px solid ${!filterDay?"#C4974A":"#222"}`,borderRadius:18,padding:"4px 12px",cursor:"pointer",color:!filterDay?"#000":"#666",fontSize:12}}>All ({photos.length})</button>
                {days.filter(d=>photos.some(p=>p.dayId===d.id)).map(d=>(
                  <button key={d.id} onClick={()=>setFilterDay(d.id)} style={{flexShrink:0,background:filterDay===d.id?d.theme:"#111",border:`1px solid ${filterDay===d.id?d.theme:"#222"}`,borderRadius:18,padding:"4px 12px",cursor:"pointer",color:filterDay===d.id?"#fff":"#666",fontSize:12}}>{d.emoji} {d.date}</button>
                ))}
              </div>
            )}
            {filteredPhotos.length===0?(
              <div style={{textAlign:"center",padding:"70px 20px"}}>
                <div style={{fontSize:44,marginBottom:14}}>🌊</div>
                <div style={{fontSize:18,color:"#333",fontStyle:"italic",marginBottom:6}}>No photos yet</div>
                <div style={{fontSize:13,color:"#2a2a2a",marginBottom:20}}>Upload your Portugal memories — AI captions and tags them by day</div>
                <button onClick={()=>setTab("upload")} style={{background:"#C4974A",color:"#000",border:"none",borderRadius:8,padding:"10px 22px",cursor:"pointer",fontSize:13}}>Add Photos →</button>
              </div>
            ):(
              <div style={{columns:"3 180px",gap:8}}>
                {filteredPhotos.map(p=>{
                  const d=days.find(x=>x.id===p.dayId);
                  return(
                    <div key={p.id} onClick={()=>setSelPhoto(p)} style={{breakInside:"avoid",marginBottom:8,borderRadius:9,overflow:"hidden",border:"1px solid #141414",cursor:"pointer",background:"#0a0908"}}>
                      <div style={{position:"relative"}}>
                        <img src={p.url} alt="" style={{width:"100%",display:"block",opacity:p.loading?.5:1}}/>
                        {p.loading&&<div style={{position:"absolute",inset:0,display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",background:"#00000080"}}><div style={{fontSize:18}}>✨</div><div style={{fontSize:9,color:"#C4974A",letterSpacing:2,marginTop:4}}>ANALYZING</div></div>}
                        {!p.loading&&d&&<div style={{position:"absolute",top:6,left:6,background:d.theme+"dd",borderRadius:4,padding:"2px 7px",fontSize:9,color:"#fff"}}>{d.emoji} {d.date}</div>}
                        <button onClick={e=>{e.stopPropagation();setPhotos(px=>px.filter(x=>x.id!==p.id));}} style={{position:"absolute",top:6,right:6,background:"#000000aa",border:"none",color:"#fff",borderRadius:"50%",width:22,height:22,cursor:"pointer",fontSize:12,lineHeight:1,display:"flex",alignItems:"center",justifyContent:"center"}}>×</button>
                      </div>
                      {!p.loading&&<div style={{padding:"8px 10px"}}>
                        {p.location&&<div style={{fontSize:10,color:"#C4974A",marginBottom:2}}>📍 {p.location}</div>}
                        {p.caption&&<div style={{fontSize:12,color:"#C8C0B8",lineHeight:1.5,fontStyle:"italic"}}>"{p.caption}"</div>}
                      </div>}
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        )}

        {/* ── UPLOAD ── */}
        {tab==="upload"&&(
          <div>
            <div onDragOver={e=>{e.preventDefault();setDragging(true);}} onDragLeave={()=>setDragging(false)} onDrop={onDrop} onClick={()=>fileIn.current.click()} style={{border:`2px dashed ${dragging?"#C4974A":"#1e1e1e"}`,borderRadius:14,padding:"50px 40px",textAlign:"center",cursor:"pointer",background:dragging?"#12100a":"#0a0908",transition:"all .3s",marginBottom:20}}>
              <div style={{fontSize:40,marginBottom:12}}>📸</div>
              <div style={{fontSize:16,color:"#C4974A",marginBottom:4,fontStyle:"italic"}}>Drop photos here</div>
              <div style={{fontSize:12,color:"#333",marginBottom:16}}>or click to browse · multiple at once</div>
              <div style={{display:"flex",gap:6,justifyContent:"center",flexWrap:"wrap"}}>
                {["📍 Auto-tagged","✍️ AI captions","🏛 Landmark ID","💡 Tips"].map(f=><div key={f} style={{fontSize:11,color:"#444",background:"#111",padding:"3px 10px",borderRadius:18,border:"1px solid #1e1e1e"}}>{f}</div>)}
              </div>
              <input ref={fileIn} type="file" accept="image/*" multiple style={{display:"none"}} onChange={async e=>{for(const f of Array.from(e.target.files)) await processFile(f); e.target.value="";}}/>
            </div>
          </div>
        )}
      </div>

      {/* PHOTO MODAL */}
      {selPhoto&&(
        <div onClick={()=>setSelPhoto(null)} style={{position:"fixed",inset:0,background:"#000000f0",zIndex:200,display:"flex",alignItems:"center",justifyContent:"center",padding:20}}>
          <div onClick={e=>e.stopPropagation()} style={{background:"#0a0908",borderRadius:14,overflow:"hidden",maxWidth:700,width:"100%",maxHeight:"90vh",overflowY:"auto",border:"1px solid #1e1e1e"}}>
            <div style={{position:"relative"}}>
              <img src={selPhoto.url} alt="" style={{width:"100%",maxHeight:340,objectFit:"cover",display:"block"}}/>
              <button onClick={()=>setSelPhoto(null)} style={{position:"absolute",top:10,right:10,background:"#000000cc",border:"none",color:"#fff",borderRadius:"50%",width:28,height:28,cursor:"pointer",fontSize:14,display:"flex",alignItems:"center",justifyContent:"center"}}>✕</button>
              {(()=>{ const d=days.find(x=>x.id===selPhoto.dayId); return d?<div style={{position:"absolute",bottom:10,left:10,background:d.theme+"ee",borderRadius:6,padding:"3px 10px",fontSize:11,color:"#fff"}}>{d.emoji} {d.date} · {d.title}</div>:null; })()}
            </div>
            <div style={{padding:"18px 22px"}}>
              {selPhoto.location&&<div style={{fontSize:12,color:"#C4974A",marginBottom:8}}>📍 {selPhoto.location}</div>}
              {selPhoto.caption&&<p style={{fontSize:15,color:"#F0E8DC",fontStyle:"italic",lineHeight:1.65,marginBottom:12}}>"{selPhoto.caption}"</p>}
              {selPhoto.story&&<div style={{marginBottom:14}}><div style={{fontSize:9,letterSpacing:3,color:"#333",textTransform:"uppercase",marginBottom:5}}>Travel Journal</div><p style={{fontSize:13,color:"#A09890",lineHeight:1.85,margin:0}}>{selPhoto.story}</p></div>}
              {selPhoto.tips?.length>0&&<div style={{background:"#111",borderRadius:8,padding:"12px 14px"}}><div style={{fontSize:9,letterSpacing:3,color:"#C4974A",textTransform:"uppercase",marginBottom:8}}>💡 Tips</div>{selPhoto.tips.map((t,i)=><div key={i} style={{display:"flex",gap:8,marginBottom:i<selPhoto.tips.length-1?6:0}}><div style={{color:"#C4974A",flexShrink:0}}>→</div><div style={{fontSize:12,color:"#907880",lineHeight:1.6}}>{t}</div></div>)}</div>}
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("app")).render(<App/>);
</script>
</body>
</html>
