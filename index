// ── AI ──────────────────────────────────────────────
async function callClaude(messages, system="", maxTokens=1000) {
  const body = {model:"claude-haiku-4-5-20251001", max_tokens:maxTokens, messages};
  if(system) body.system = system;
  const r = await fetch("/.netlify/functions/claude",{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify(body)
  });
  const d = await r.json();
  return d.text||"";
}

async function aiSuggestItem(dayCtx, sectionTitle, sectionType, existing) {
  const prompt = `Portugal travel expert. Couple, Algarve + Lisbon, July 3–12 2026.
Day: ${dayCtx}
Section: ${sectionTitle} (type: ${sectionType})
Existing items: ${existing.map(i=>i.name||i.label).join(", ")||"none"}

Suggest ONE new ${sectionType==="logistics"?"logistics row":"activity/event"} that fits perfectly.
Return ONLY valid JSON with these fields:
${sectionType==="logistics"
  ? '{"label":"","value":""}'
  : '{"name":"","time":"","description":"","tip":"","address":"","phone":"","link":"","bookingNote":"","mustOrder":""}'}
No markdown. Fill only relevant fields, leave others as empty string.`;
  const t = await callClaude([{role:"user",content:prompt}]);
  try { return JSON.parse(t.replace(/```json|```/g,"").trim()); } catch { return null; }
}

async function aiEditItem(item, request, ctx) {
  const t = await callClaude([{role:"user",content:`Portugal travel expert. Edit this for a couple, Algarve + Lisbon, July 3–12 2026.\nContext: ${ctx}\nCurrent: ${JSON.stringify(item)}\nRequest: "${request}"\nReturn ONLY valid JSON, same fields. No markdown.`}]);
  try { return JSON.parse(t.replace(/```json|```/g,"").trim()); } catch { return null; }
}

async function aiChat(msg, days, history) {
  const summary = days.map(d=>`${d.date} (${d.day}): ${d.title} — ${d.sections.flatMap(s=>s.items).map(i=>i.name||i.label).filter(Boolean).join(", ")}`).join("\n");
  return await callClaude(
    [...history,{role:"user",content:msg}],
    `Expert Portugal travel concierge. Couple, Algarve + Lisbon, July 3–12 2026.\nFull itinerary:\n${summary}\nBe specific, warm, practical. Max 200 words.`,
    800
  );
}

async function aiPhoto(b64, mime, days) {
  const places = days.flatMap(d=>d.sections.flatMap(s=>s.items).map(i=>i.name||i.label).filter(Boolean).map(n=>`${d.date}: ${n}`)).join(", ");
  const r = await fetch("/.netlify/functions/claude",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({
    model:"claude-haiku-4-5-20251001",max_tokens:600,
    messages:[{role:"user",content:[
      {type:"image",source:{type:"base64",media_type:mime,data:b64}},
      {type:"text",text:`Portugal trip photo. Places visited: ${places}. Return ONLY JSON:\n{"dayId":<1-10|null>,"location":"<place>","caption":"<1-sentence first-person>","mood":"<golden|serene|dramatic|vibrant|mysterious|festive|intimate|wild>","story":"<2-3 sentence journal>","tips":["t1","t2","t3"]}`}
    ]}]
  })});
  const d = await r.json();
  try { return JSON.parse((d.content?.[0]?.text||"{}").replace(/```json|```/g,"").trim()); }
  catch { return {location:"Portugal",caption:"A beautiful moment.",mood:"golden",story:"An unforgettable scene.",tips:[]}; }
}

