// ── EDITABLE INLINE TEXT ─────────────────────────────
function Editable({value, onChange, multiline=false, style={}, placeholder="", className=""}) {
  const [editing,setEditing] = useState(false);
  const [val,setVal] = useState(value);
  const ref = useRef();
  useEffect(()=>{ if(editing) ref.current?.focus(); },[editing]);
  useEffect(()=>setVal(value),[value]);
  const commit = ()=>{ setEditing(false); if(val!==value) onChange(val); };
  const base = {background:"#0D0D0D",border:"1px solid #C4974A55",borderRadius:4,padding:"3px 7px",color:"#F0E8DC",resize:"vertical",outline:"none",width:"100%",...style};
  if(editing) return multiline
    ? <textarea ref={ref} value={val} onChange={e=>setVal(e.target.value)} onBlur={commit} style={{...base,minHeight:52,fontSize:13,lineHeight:1.6,fontFamily:"'EB Garamond',Georgia,serif"}}/>
    : <input ref={ref} value={val} onChange={e=>setVal(e.target.value)} onBlur={commit} onKeyDown={e=>e.key==="Enter"&&commit()} style={{...base,fontSize:13,fontFamily:"'EB Garamond',Georgia,serif"}}/>;
  return <span onClick={()=>setEditing(true)} title="Click to edit" style={{cursor:"text",borderBottom:"1px dashed #2a2a2a",paddingBottom:1,...style}}>{val||<span style={{color:"#333",fontStyle:"italic"}}>{placeholder||"click to edit"}</span>}</span>;
}

